<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc admin-stats-window-title}"
    MinSize="700 340"
    SetSize="720 340">
    <BoxContainer Orientation="Vertical" Margin="6">

        <!-- Row 1: NPC | Shuttles | Objects -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="6">

            <!-- NPC Card -->
            <PanelContainer Name="NpcPanel" HorizontalExpand="True" Margin="0">
                <BoxContainer Orientation="Vertical" Margin="8 6">
                    <Label Text="{Loc admin-stats-section-npc}" StyleClasses="LabelHeading" Margin="0 0 0 4" />
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-npc-active}" HorizontalExpand="True" />
                        <Label Name="NpcActiveLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-npc-sleeping}" HorizontalExpand="True" />
                        <Label Name="NpcSleepingLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-npc-total}" HorizontalExpand="True" />
                        <Label Name="NpcTotalLabel" Text="—" StyleClasses="LabelKeyText" />
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>

            <!-- Shuttles Card -->
            <PanelContainer Name="ShuttlesPanel" HorizontalExpand="True" Margin="0">
                <BoxContainer Orientation="Vertical" Margin="8 6">
                    <Label Text="{Loc admin-stats-section-shuttles}" StyleClasses="LabelHeading" Margin="0 0 0 4" />
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-shuttles-active}" HorizontalExpand="True" />
                        <Label Name="ShuttlesActiveLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-shuttles-paused}" HorizontalExpand="True" />
                        <Label Name="ShuttlesPausedLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-shuttles-total}" HorizontalExpand="True" />
                        <Label Name="ShuttlesTotalLabel" Text="—" StyleClasses="LabelKeyText" />
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>

            <!-- Objects Card -->
            <PanelContainer Name="DebrisPanel" HorizontalExpand="True" Margin="0">
                <BoxContainer Orientation="Vertical" Margin="8 6">
                    <Label Text="{Loc admin-stats-section-debris}" StyleClasses="LabelHeading" Margin="0 0 0 4" />
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-debris-asteroids}" HorizontalExpand="True" />
                        <Label Name="DebrisCountLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-debris-wrecks}" HorizontalExpand="True" />
                        <Label Name="WrecksCountLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-debris-total}" HorizontalExpand="True" />
                        <Label Name="DebrisTotalLabel" Text="—" StyleClasses="LabelKeyText" />
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>

        <Control MinHeight="6" />

        <!-- Row 2: Players | StarGate | Resources -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="6">

            <!-- Players Card -->
            <PanelContainer Name="PlayersPanel" HorizontalExpand="True" Margin="0">
                <BoxContainer Orientation="Vertical" Margin="8 6">
                    <Label Text="{Loc admin-stats-section-players}" StyleClasses="LabelHeading" Margin="0 0 0 4" />
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-players-alive}" HorizontalExpand="True" />
                        <Label Name="PlayersAliveLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-players-dead}" HorizontalExpand="True" />
                        <Label Name="PlayersDeadLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-players-cryo}" HorizontalExpand="True" />
                        <Label Name="PlayersInCryoLabel" Text="—" />
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>

            <!-- StarGate Card -->
            <PanelContainer Name="StargatePanel" HorizontalExpand="True" Margin="0">
                <BoxContainer Orientation="Vertical" Margin="8 6">
                    <Label Text="{Loc admin-stats-section-stargate}" StyleClasses="LabelHeading" Margin="0 0 0 4" />
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-stargate-active}" HorizontalExpand="True" />
                        <Label Name="StargateMapsActiveLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-stargate-frozen}" HorizontalExpand="True" />
                        <Label Name="StargateMapsFrozenLabel" Text="—" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal">
                        <Label Text="{Loc admin-stats-stargate-total}" HorizontalExpand="True" />
                        <Label Name="StargateMapsToLabel" Text="—" StyleClasses="LabelKeyText" />
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>

            <!-- Resources Card -->
            <PanelContainer Name="ResourcesPanel" HorizontalExpand="True" Margin="0">
                <BoxContainer Orientation="Vertical" Margin="8 6">
                    <Label Text="{Loc admin-stats-section-resources}" StyleClasses="LabelHeading" Margin="0 0 0 4" />
                    <BoxContainer Orientation="Horizontal" Margin="0 2 0 0">
                        <Label Text="{Loc admin-stats-ram}" MinWidth="40" />
                        <Label Name="RamLabel" Text="—" MinWidth="110" />
                    </BoxContainer>
                    <ProgressBar Name="RamBar" HorizontalExpand="True"
                                 MinValue="0" MaxValue="100" Value="0" Page="0"
                                 MinHeight="16" Margin="0 1" />
                    <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                        <Label Text="{Loc admin-stats-cpu}" MinWidth="40" />
                        <Label Name="CpuLabel" Text="—" MinWidth="110" />
                    </BoxContainer>
                    <ProgressBar Name="CpuBar" HorizontalExpand="True"
                                 MinValue="0" MaxValue="100" Value="0" Page="0"
                                 MinHeight="16" Margin="0 1" />
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
