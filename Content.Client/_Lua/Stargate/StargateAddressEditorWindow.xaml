<DefaultWindow xmlns="https://spacestation14.io"
              Title="{Loc 'stargate-editor-title'}"
              MinSize="1200 570">
  <BoxContainer Orientation="Horizontal" HorizontalExpand="True" VerticalExpand="True" Margin="5">
    <PanelContainer Name="LeftDiskPanel" MinWidth="330" Margin="0 0 5 0" VerticalExpand="True">
      <BoxContainer Orientation="Vertical" Margin="5" VerticalExpand="True">
        <Label Name="LeftDiskTitleLabel"
               Text="{Loc 'stargate-editor-disk-left'}"
               HorizontalAlignment="Center"
               StyleClasses="LabelHeading" />
        <Button Name="SaveToLeftButton"
                Text="{Loc 'stargate-editor-save-left'}"
                HorizontalAlignment="Stretch"
                Margin="0 4 0 4" />
        <ScrollContainer VerticalExpand="True" HorizontalExpand="True" MinHeight="200">
          <BoxContainer Name="LeftDiskAddressList" Orientation="Vertical" HorizontalExpand="True" />
        </ScrollContainer>
      </BoxContainer>
    </PanelContainer>

    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" MinWidth="480">
      <PanelContainer Margin="0 0 0 5">
        <BoxContainer Orientation="Vertical" Margin="5">
          <Label Name="AddressDisplay"
                 Text="_ _ _ _ _ _"
                 HorizontalAlignment="Center"
                 StyleClasses="LabelHeading" />
        </BoxContainer>
      </PanelContainer>
      <LayoutContainer Name="DhdRingContainer"
                       MinSize="440 440"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
      <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 0">
        <Button Name="ClearButton"
                Text="{Loc 'stargate-console-clear'}"
                MinWidth="100"
                Margin="5 0" />
      </BoxContainer>
    </BoxContainer>

    <PanelContainer Name="RightDiskPanel" MinWidth="330" Margin="5 0 0 0" VerticalExpand="True">
      <BoxContainer Orientation="Vertical" Margin="5" VerticalExpand="True">
        <Label Name="RightDiskTitleLabel"
               Text="{Loc 'stargate-editor-disk-right'}"
               HorizontalAlignment="Center"
               StyleClasses="LabelHeading" />
        <Button Name="SaveToRightButton"
                Text="{Loc 'stargate-editor-save-right'}"
                HorizontalAlignment="Stretch"
                Margin="0 4 0 4" />
        <ScrollContainer VerticalExpand="True" HorizontalExpand="True" MinHeight="200">
          <BoxContainer Name="RightDiskAddressList" Orientation="Vertical" HorizontalExpand="True" />
        </ScrollContainer>
      </BoxContainer>
    </PanelContainer>
  </BoxContainer>
</DefaultWindow>
