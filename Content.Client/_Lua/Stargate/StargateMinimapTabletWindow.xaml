<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'stargate-minimap-title'}"
                      SetSize="750 520"
                      MinSize="750 520">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer Name="MapPanel"
                        VerticalExpand="True"
                        HorizontalExpand="True"
                        Margin="4 4 4 2" />
        <BoxContainer Orientation="Horizontal" Margin="4 2 4 2" SeparationOverride="4">
            <Label Name="Disk1Label" HorizontalExpand="True" />
            <Button Name="MergeTo2Button" MinSize="60 0" />
            <Button Name="MergeTo1Button" MinSize="60 0" />
            <Label Name="Disk2Label" HorizontalExpand="True" HorizontalAlignment="Right" />
        </BoxContainer>
        <Label Name="StatusLabel" Margin="4 0 4 4" FontColorOverride="#555555" />
    </BoxContainer>
</controls:FancyWindow>
