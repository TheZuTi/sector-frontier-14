<controls:FancyWindow xmlns="https://spacestation14.io"
              xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
              xmlns:lua="clr-namespace:Content.Client._Lua.Stargate.UI"
              Title="{Loc 'stargate-shuttle-beacon-ui-title'}"
              Resizable="False"
              SetSize="520 660">
  <BoxContainer Orientation="Vertical" Margin="8" HorizontalExpand="True">

    <Label Name="StatusLabel"
           Text="{Loc 'stargate-shuttle-beacon-ui-no-card'}"
           HorizontalAlignment="Center"
           Margin="0 0 0 4"/>

    <Button Name="RecallButton"
            Text="{Loc 'stargate-shuttle-beacon-ui-recall'}"
            HorizontalAlignment="Center"
            MinWidth="180"
           Margin="0 2 0 10"
            Visible="False"/>

    <lua:StarGateLandingPickerControl Name="LandingPicker"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           SetSize="480 480"
          Margin="0 4 0 4"/>

  </BoxContainer>
</controls:FancyWindow>
